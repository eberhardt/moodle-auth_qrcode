{{!
    @template auth_qrcode/login
}}
<div id="auth_qrcode">
    <h3>Login with QR-Code</h3>
    <div id="qrcode-container" class="mt-5 mb-5">
        <img id="qrcode-image" src="{{qrcode_data}}" />
        <div class="qrcode-instructions mt-5 text-left">
            <ol>
                <li>{{#str}}instruction_1, auth_qrcode{{/str}}</li>
                <li>{{#str}}instruction_2, auth_qrcode{{/str}}</li>
                <li>{{#str}}instruction_3, auth_qrcode{{/str}}</li>
            </ol>
        </div>
    </div>
    <div id="expired-container" class="text-center mb-3 hidden">
        <p>{{#str}}qrcode_expired, auth_qrcode{{/str}}</p>
        <a href="/auth/qrcode/login.php" class="btn btn-primary w-75">{{#str}}get_new_qrcode, auth_qrcode{{/str}}</a>
    </div>
    <div id="rejected-container" class="text-center mb-5 hidden">
        <p>{{#str}}login_rejected, auth_qrcode{{/str}}</p>
    </div>
    <div class="text-center">
        <a href="/login/" class="btn btn-secondary w-75">Back to Login</a>
    </div>
</div>
