{{!
    @template auth_qrcode/confirmationcode

    Example context (json):
    {
        "sesskey": "abcdef0123456",
        "confirmationcode": "1234"
    }
}}
<div class="confirmation-container">
    <div class="confirmation-message mt-3 mb-3">
        {{#str}}confirmationcodeexplanation, auth_qrcode{{/str}}
    </div>
    <div class="confirmationcode text-center mb-3">
        {{confirmationcode}}
    </div>
    <form class="confirmation-buttons text-center" method="post">
        <input type="hidden" name="sesskey" value="{{sesskey}}">
        <button type="submit" name="deny" value="1" class="btn btn-secondary w-50">{{#str}}cancel_login, auth_qrcode{{/str}}</button>
    </form>
</div>
